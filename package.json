{
  "name": "comment-class",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "web",
    "node"
  ],
  "scripts": {
    "serve": "npm run serve --workspace=web",
    "start": "npm run start --workspace=node",
    "start:node": "npm run start --workspace=node",
    "start:web": "npm run serve --workspace=web",
    "test": "npm run test --workspace=node && npm run test --workspace=web",
    "test:watch": "npm run test:watch --workspace=node",
    "test:web": "npm run test --workspace=web",
    "test:web:watch": "npm run test:watch --workspace=web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  }
}
